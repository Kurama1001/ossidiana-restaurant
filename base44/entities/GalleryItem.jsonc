{
  "name": "GalleryItem",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "image",
        "video"
      ],
      "default": "image",
      "description": "Tipo di media"
    },
    "url": {
      "type": "string",
      "description": "URL del file caricato"
    },
    "caption": {
      "type": "string",
      "description": "Didascalia opzionale"
    },
    "sortOrder": {
      "type": "number",
      "description": "Ordine di visualizzazione"
    },
    "active": {
      "type": "boolean",
      "default": true,
      "description": "Visibile in home"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Immagine di rilievo (appare grande in cima alla galleria)"
    },
    "focalPoint": {
      "type": "string",
      "enum": [
        "top",
        "center",
        "bottom"
      ],
      "default": "center",
      "description": "Punto focale per il ritaglio"
    }
  },
  "required": [
    "url",
    "type"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {},
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}